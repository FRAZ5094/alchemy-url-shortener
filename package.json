{
  "name": "alchemy-url-shortener",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "alchemy dev",
    "dev:worker": "alchemy dev",
    "dev:web": "bun run --filter web dev",
    "build:web": "bun run --filter web build",
    "deploy:dev": "alchemy deploy --stage dev_fraser",
    "deploy:prod": "alchemy deploy --stage prod",
    "destroy:dev": "alchemy destroy --stage dev_fraser --yes",
    "destroy:test": "alchemy destroy --stage test --yes",
    "typecheck": "tsc --noEmit",
    "effect:check": "effect-language-service check",
    "effect:diagnostics": "effect-language-service diagnostics --project tsconfig.json",
    "prepare": "effect-language-service patch"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform-bun": ">=4.0.0-beta.60 || >=4.0.0",
    "@effect/platform-node": ">=4.0.0-beta.60 || >=4.0.0",
    "alchemy": "2.0.0-beta.35",
    "effect": ">=4.0.0-beta.60 || >=4.0.0"
  }
}
